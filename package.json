{
  "name": "rmc-auth",
  "version": "1.0.0",
  "description": "Multi Auth tools for your project, minimizing the time spent with configurations and extremely detailed stuff.",
  "author": "rmcampigotto",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "keywords": [
    "auth",
    "authentication",
    "nestjs",
    "jwt",
    "security",
    "rbac",
    "crypt",
    "password",
    "guards"
  ],
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/jwt": "^10.0.0 || ^11.0.0",
    "@nestjs/passport": "^10.0.0 || ^11.0.0",
    "passport": "^0.6.0 || ^0.7.0",
    "passport-jwt": "^4.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "bcrypt": "^6.0.0",
    "owasp-password-strength-test": "^1.3.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.14",
    "@nestjs/common": "^11.1.14",
    "@nestjs/core": "^11.1.14",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@swc/core": "^1.15.18",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.3.3",
    "@types/jest": "^29.5.14",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^29.7.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.2.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
